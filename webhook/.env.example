# Meridian CPD Webhook — Environment Variables
# Copy this to .env for local testing, or add each as a Railway environment variable

# ── Stripe ─────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...         # Stripe Dashboard → Developers → API Keys
STRIPE_WEBHOOK_SECRET=whsec_...       # Stripe Dashboard → Developers → Webhooks → signing secret
STRIPE_PRICE_SINGLE=price_...         # Price ID for £19.99 single course (MER-DEA-001)
STRIPE_PRICE_SUBSCRIPTION=price_...   # Price ID for £79/yr subscription

# ── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://cpkyloywjmpesmjgqaxm.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...      # Supabase Dashboard → Settings → API → service_role

# ── Gmail OAuth (for sending emails from hello@meridiancpd.co.uk) ─────────────
# See DEPLOY.md for how to get these values
GMAIL_CLIENT_ID=...apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-...
GMAIL_REFRESH_TOKEN=1//...

# ── App ────────────────────────────────────────────────────────────────────────
BASE_URL=https://meridiancpd.co.uk    # no trailing slash

# ── Course PDF URLs (Supabase Storage public URLs) ────────────────────────────
# After uploading PDFs to Supabase Storage bucket 'courses', add the public URLs here
PDF_MER_DEA_001=https://cpkyloywjmpesmjgqaxm.supabase.co/storage/v1/object/public/courses/MER-DEA-001.pdf
PDF_MER_DEA_002=https://cpkyloywjmpesmjgqaxm.supabase.co/storage/v1/object/public/courses/MER-DEA-002.pdf
